# ---------------------------------------------------------------------------
# h3-explorer-ui — root ignore rules.
# The frontend also has its own frontend/.gitignore (SvelteKit conventions);
# this file covers the whole monorepo.
# ---------------------------------------------------------------------------

# --- Go (backend) ---
# (gitignore has no inline comments — keep notes on their own lines)
/backend/bin/
# default `go build ./cmd/server` output
/backend/server
/backend/dist/
# `go test -c` binaries
*.test
# coverage / profiling output
*.out
coverage.*
*.prof

# --- Node / SvelteKit (frontend) ---
node_modules/
.svelte-kit/
/frontend/build/
/frontend/.output/
/frontend/.vercel/
/frontend/.netlify/
/frontend/.wrangler/
vite.config.*.timestamp-*

# --- Environment files (never commit secrets) ---
.env
.env.*
!.env.example

# --- Docker ---
*.tar

# --- Logs ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Editors / IDEs ---
.idea/
.vscode/*
!.vscode/extensions.json
*.swp
*.swo

# --- OS cruft ---
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
