# Where the SvelteKit dev/prod server proxies API calls. The browser always
# calls same-origin /api; this is the upstream Go backend.
#   - local dev:        http://localhost:8080  (default)
#   - docker-compose:   http://backend:8080
API_PROXY_TARGET=http://localhost:8080

# Port the adapter-node server listens on (production).
PORT=3000
